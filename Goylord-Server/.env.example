# Goylord Server Environment Configuration
# Copy this file to .env and customize for your deployment

# Server Configuration
PORT=5173
HOST=0.0.0.0

# Optional: Set custom hostname for certificate generation
# GOYLORD_HOSTNAME=your-server.com

# Authentication
GOYLORD_USER=admin
# Default bootstrap password is "admin" unless you override it
GOYLORD_PASS=admin

# Optional overrides. Leave empty to auto-generate and persist in ./data/save.json
JWT_SECRET=
GOYLORD_AGENT_TOKEN=

# TLS/HTTPS Configuration (Always Enabled)
# Certificates are auto-generated if not present
# You can specify custom certificate paths:
# GOYLORD_TLS_CERT=./certs/server.crt
# GOYLORD_TLS_KEY=./certs/server.key

# Optional: CA certificate for client certificate verification (mutual TLS)
# GOYLORD_TLS_CA=./certs/ca.crt

# Performance tuning
PRUNE_BATCH=500
