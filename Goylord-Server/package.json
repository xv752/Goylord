{
  "name": "goylord-server",
  "version": "0.0.5",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun run build && bun dist/index.js",
    "build": "bun run build:css && bun run vendor && bun run build:bundle",
    "build:public:prod": "bun run build:css && bun run vendor && bun run minify",
    "build:bundle": "bun build --production src/index.ts --target bun --outfile dist/index.js && bun build --production src/server/plugin-runtime/worker-host.ts --target bun --outfile dist/server/plugin-runtime/worker-host.js",
    "vendor": "bun run scripts/vendor.ts",
    "build:prod:win": "bun run build:public:prod && bun build --production src/index.ts --compile --target bun-windows-x64 --outfile dist/goylord-server.exe",
    "build:prod:linux": "bun run build:public:prod && bun build --production src/index.ts --compile --target bun-linux-x64 --outfile dist/goylord-server-linux-x64",
    "build:css": "tailwindcss -i ./src/styles.css -o ./public/assets/tailwind.css --minify",
    "watch:css": "tailwindcss -i ./src/styles.css -o ./public/assets/tailwind.css --watch",
    "minify": "bun run scripts/minify-public.ts",
    "bench:client-db": "bun run scripts/client-db-stress.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hotwired/stimulus": "^3.2.2",
    "@hotwired/turbo": "^8.0.23",
    "@msgpack/msgpack": "^3.0.0",
    "@solana/web3.js": "^1.98.4",
    "adm-zip": "^0.5.12",
    "ansi-to-html": "0.7.2",
    "cytoscape": "^3.34.0",
    "fuse.js": "^7.4.1",
    "geoip-lite": "latest",
    "gridstack": "^12.6.0",
    "jose": "^6.1.3",
    "msgpackr": "1.11.8",
    "qrcode": "^1.5.4",
    "uuid": "^9.0.1",
    "web-push": "^3.6.7",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fortawesome/fontawesome-free": "6.5.2",
    "@tailwindcss/cli": "^4.1.18",
    "@types/bun": "^1.3.9",
    "@types/geoip-lite": "latest",
    "@types/uuid": "^9.0.7",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "ace-builds": "1.36.5",
    "animejs": "3.2.2",
    "autoprefixer": "^10.4.23",
    "chart.js": "4.4.0",
    "clean-css": "^5.3.3",
    "codemirror": "5.65.16",
    "flag-icons": "latest",
    "highlight.js": "11.9.0",
    "html-minifier-terser": "^7.2.0",
    "monaco-editor": "^0.55.1",
    "postcss": "^8.5.6",
    "tabulator-tables": "^6.4.0",
    "tailwindcss": "^4.1.18",
    "terser": "^5.46.1",
    "typescript": "^5.6.3"
  }
}
