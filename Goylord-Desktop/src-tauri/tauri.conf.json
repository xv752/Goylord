{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Goylord",
  "version": "0.0.0",
  "identifier": "com.goylord.desktop",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.icns",
      "icons/icon.png",
      "icons/128x128@2x.png",
      "icons/128x128.png",
      "icons/32x32.png"
    ],
    "shortDescription": "Goylord Desktop Client",
    "longDescription": "Native desktop fat client for the Goylord server.",
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine",
        "displayLanguageSelector": false,
        "languages": ["English"]
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
