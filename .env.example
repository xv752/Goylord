# Goylord Configuration (Optional Overrides)
# 
# Most users don't need to create a .env file!
# The docker-compose.yml has sensible defaults.
#
# On first startup, secrets are auto-generated and persisted in ./data/save.json
# when not explicitly provided.
#
# Only create .env if you want to customize:

# ============================================
# PRODUCTION: Use pre-built image
# ============================================
# Set this to pull from registry instead of building locally
# DOCKER_IMAGE=ghcr.io/yourusername/goylord-server:latest

# ============================================
# OPTIONAL: Custom initial admin username
# ============================================
# Default is "admin" - change if you prefer a different username
# GOYLORD_USER=myadmin

# OPTIONAL: Custom initial admin password
# Default is "admin"
# GOYLORD_PASS=admin

# ============================================
# OPTIONAL: Custom port
# ============================================
# Default is 5173
# PORT=8080

# ============================================
# ADVANCED: Custom JWT secret
# ============================================
# Leave empty to auto-generate and persist to save.json (recommended)
# JWT_SECRET=

# OPTIONAL: Agent authentication token
# Leave empty to auto-generate and persist to save.json
# GOYLORD_AGENT_TOKEN=

# OPTIONAL: Solana publisher RPC request limits (per signed-in user)
# GOYLORD_SOL_PUBLISH_RATE_LIMIT_MAX=3
# GOYLORD_SOL_PUBLISH_RATE_LIMIT_WINDOW_SECONDS=300
# GOYLORD_SOL_PUBLISH_RATE_LIMIT_LOCKOUT_SECONDS=300
# GOYLORD_SOL_BALANCE_RATE_LIMIT_MAX=12
# GOYLORD_SOL_BALANCE_RATE_LIMIT_WINDOW_SECONDS=60
# GOYLORD_SOL_BALANCE_RATE_LIMIT_LOCKOUT_SECONDS=60

# ============================================
# OPTIONAL: OIDC / SSO login
# ============================================
# Generic OIDC works with providers such as Authentik, Authelia, Keycloak, Zitadel, and Dex.
# Configure your provider callback/redirect URI as:
#   https://YOUR_GOYLORD_HOST/api/oidc/callback
# Keep local username/password login enabled as a fallback.
# GOYLORD_OIDC_ENABLED=true
# GOYLORD_OIDC_LABEL=Sign in with SSO
# GOYLORD_OIDC_ISSUER=https://auth.example.com/application/o/goylord/
# GOYLORD_OIDC_CLIENT_ID=goylord
# GOYLORD_OIDC_CLIENT_SECRET=change-me
# GOYLORD_OIDC_REDIRECT_URI=https://goylord.example.com/api/oidc/callback
# GOYLORD_OIDC_DEFAULT_ROLE=viewer
# GOYLORD_OIDC_ALLOWED_DOMAINS=example.com
# GOYLORD_OIDC_ADMIN_GROUPS=goylord-admins
# GOYLORD_OIDC_OPERATOR_GROUPS=goylord-operators
# GOYLORD_OIDC_VIEWER_GROUPS=goylord-viewers

# ============================================
# OPTIONAL: Login screen branding
# ============================================
# Use a logo URL, or leave it empty and set a Font Awesome icon class.
# Logo URLs may be absolute http(s) URLs or root-relative paths such as /assets/logo.png.
# GOYLORD_LOGIN_BRAND_NAME=Acme SOC
# GOYLORD_NAV_BRAND_NAME=Acme Console
# GOYLORD_BRAND_ACCENT_COLOR=#14b8a6
# GOYLORD_LOGIN_TITLE=Welcome to Acme Goylord
# GOYLORD_LOGIN_SUBTITLE=Sign in with your Acme identity
# GOYLORD_LOGIN_LOGO_URL=/assets/acme-logo.png
# GOYLORD_LOGIN_LOGO_ALT=Acme logo
# GOYLORD_NAV_LOGO_URL=/assets/acme-nav-logo.png
# GOYLORD_NAV_LOGO_ALT=Acme logo
# GOYLORD_LOGIN_HERO_IMAGE_URL=/assets/acme-login.jpg
# GOYLORD_LOGIN_HERO_IMAGE_ALT=Acme operations center
# GOYLORD_LOGIN_FOOTER_TEXT=Authorized Acme access only
# GOYLORD_LOGIN_SUPPORT_TEXT=Need access help?
# GOYLORD_LOGIN_SUPPORT_URL=https://help.example.com
# GOYLORD_LOGIN_ICON_CLASS=fa-solid fa-shield-halved

# ============================================
# ADVANCED: Custom TLS certificates
# ============================================
# Leave as defaults to use auto-generated self-signed certs
# GOYLORD_TLS_CERT=/custom/path/server.crt
# GOYLORD_TLS_KEY=/custom/path/server.key

# ============================================
# ADVANCED: Reverse proxy / domain deployments
# ============================================
# If Goylord sits behind a reverse proxy (nginx, Caddy, Cloudflare, Traefik, Render,
# etc.), the server otherwise sees the proxy's IP for every agent connection — the
# dashboard, audit log, and IP bans all end up showing the proxy/Docker bridge IP
# (commonly 172.x.x.x) instead of the real client. Set this to true ONLY when a
# trusted reverse proxy is in front of Goylord; otherwise agents could spoof
# their IP by sending their own X-Forwarded-For header. Auto-enabled when
# GOYLORD_TLS_OFFLOAD=true. Honors X-Forwarded-For, X-Real-IP, CF-Connecting-IP.
# GOYLORD_TRUST_PROXY=true

# Agent builder settings (only needed if building agents)
# TARGETS=windows/amd64,windows/386,windows/arm64,linux/amd64,linux/arm64,linux/arm/v7,darwin/amd64,darwin/arm64
# GO_BUILD_FLAGS=-trimpath
# LDFLAGS=-s -w
